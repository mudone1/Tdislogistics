// Prisma schema for the Airline Connector Framework.
//
// This is intentionally a separate data store from the rest of the app
// (which uses Firestore/localStorage — see src/lib/store.tsx). Wallet sync
// data is structured, relational, and needs transactional history — a good
// fit for Postgres. After a successful sync, SyncService also mirrors the
// current balance into the existing Firestore `balances` document so the
// Airlines/Balances UI updates without any client-side changes (see
// src/modules/airline-connectors/services/SyncService.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Migrations need a direct (non-pooled) connection — PgBouncer/Neon's
  // pooler doesn't support the session-level operations `prisma migrate`
  // needs. The app's actual runtime queries keep using the pooled
  // DATABASE_URL above (better for serverless), this is only used by the
  // Prisma CLI for migrate/introspect.
  directUrl = env("DIRECT_URL")
}

enum AirlineKey {
  AIRPEACE
  AERO
  ARIK
  IBOM
  NGEAGLE
  // Category B — reserved for Phase 2, not implemented yet.
  UNITED
  RANO
  ENUGU
  XEJET
}

enum SyncStatus {
  SUCCESS
  FAILED
  IN_PROGRESS
  PENDING
}

enum SyncTrigger {
  MANUAL
  SCHEDULED
}

model AirlineWallet {
  id             String     @id @default(cuid())
  airline        AirlineKey @unique
  currentBalance Decimal    @default(0) @db.Decimal(14, 2)
  currency       String     @default("NGN")
  lastSynced     DateTime?
  lastStatus     SyncStatus @default(PENDING)
  updatedAt      DateTime   @updatedAt
  createdAt      DateTime   @default(now())

  history AirlineBalanceHistory[]
  settings AirlineConnectorSettings?

  @@map("airline_wallets")
}

// Append-only. A sync NEVER overwrites a previous record — every run
// (successful or failed) inserts a new row, so balance history and audit
// trail are always intact.
model AirlineBalanceHistory {
  id          String     @id @default(cuid())
  airline     AirlineKey
  balance     Decimal    @db.Decimal(14, 2)
  currency    String     @default("NGN")
  retrievedAt DateTime   @default(now())
  syncStatus  SyncStatus
  connector   String // e.g. "AirPeaceConnector" — which connector produced this row
  trigger     SyncTrigger @default(MANUAL)
  errorMessage String?
  createdAt   DateTime   @default(now())

  wallet   AirlineWallet @relation(fields: [airline], references: [airline])

  @@index([airline, retrievedAt])
  @@map("airline_balance_history")
}

// Per-airline connector configuration, managed from Admin → Airline Connectors.
// `encryptedUsername`/`encryptedPassword` are AES-256-GCM ciphertext (see
// CredentialService) — plaintext credentials are never persisted or sent to
// the frontend.
model AirlineConnectorSettings {
  id                 String      @id @default(cuid())
  airline            AirlineKey  @unique
  enabled            Boolean     @default(false)
  encryptedUsername  String?
  encryptedPassword  String?
  syncIntervalMinutes Int?       // null = manual only. 120 = every 2 hours, 1440 = daily.
  dailyRunAtUtc      String?     // "00:00" style, used when syncIntervalMinutes is null and a fixed daily time is wanted
  connectionStatus   String      @default("NOT_CONFIGURED") // NOT_CONFIGURED | CONNECTED | ERROR
  lastTestedAt       DateTime?
  updatedAt          DateTime    @updatedAt
  createdAt          DateTime    @default(now())

  wallet AirlineWallet @relation(fields: [airline], references: [airline])

  @@map("airline_connector_settings")
}

// Structured sync logs — Login Started, Login Success, Navigation, Balance
// Retrieved, Balance Saved, Logout, Errors — one row per event, per run.
model AirlineSyncLog {
  id        String   @id @default(cuid())
  airline   AirlineKey
  runId     String // groups all log lines for a single sync attempt
  step      String // e.g. LOGIN_STARTED, LOGIN_SUCCESS, NAVIGATION, BALANCE_RETRIEVED, BALANCE_SAVED, LOGOUT, ERROR
  message   String
  level     String   @default("info") // info | warn | error
  createdAt DateTime @default(now())

  @@index([airline, runId])
  @@map("airline_sync_logs")
}

// ─── AI Travel Assistant (chat bubble) ───
// One row per distinct chat session — keyed either by the Firebase auth
// uid (logged-in users) or a browser-generated anonymous id persisted in
// localStorage (guest/demo users). `slots` holds the short-term memory the
// conversation orchestrator fills in turn by turn (origin, destination,
// date, pax, etc.) so the assistant only asks for what's still missing.
model ChatSession {
  id           String   @id @default(cuid())
  sessionKey   String   @unique
  displayName  String?
  isAuthenticated Boolean @default(false)
  slots        Json?
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @updatedAt

  messages      ChatMessage[]
  searches      FlightSearchRecord[]
  notifications AppNotification[]

  @@map("chat_sessions")
}

enum ChatRole {
  USER
  ASSISTANT
}

// Append-only turn log. `intent`/`entities` are populated only when the
// LLM path ran (see ConversationOrchestrator) — null on the deterministic
// fallback path used when GROQ_API_KEY isn't configured.
model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      ChatRole
  text      String
  intent    String?
  entities  Json?
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

// One row per completed search (a leg, not a whole round-trip — a
// round-trip produces two rows, one per direction, so each leg gets its
// own reference ID and can be reopened independently). `resultsJson` is
// a full FlightSearchResult snapshot so a reopened search shows exactly
// what the agent originally quoted, not a live re-search that might
// return different prices later.
model FlightSearchRecord {
  id          String   @id @default(cuid())
  referenceId String   @unique
  sessionId   String
  origin      String
  destination String
  date        String
  airlines    String[]
  resultCount Int
  resultsJson Json
  createdAt   DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, createdAt])
  @@map("flight_search_records")
}

// In-app notification center. One row per event worth surfacing to the
// user (quote generated, search saved, system alert). Persisted (not just
// client-side state) so notifications survive reloads/new tabs and can be
// polled from any device signed into the same session.
model AppNotification {
  id        String   @id @default(cuid())
  sessionId String
  kind      String // QUOTE_GENERATED | SYSTEM_ALERT
  title     String
  body      String
  link      Json? // arbitrary click-through payload (e.g. { referenceId })
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, createdAt])
  @@map("app_notifications")
}
