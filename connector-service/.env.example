# ─── connector-service environment ───
# This is a SEPARATE deployment from the Next.js app — it needs its own env
# vars, set wherever you actually run it (VPS, Docker host, etc.), not in
# the Next.js app's .env.local.

PORT=4100

# Shared secret the Next.js app's API routes must send as the
# `x-internal-api-key` header on every request to this service. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONNECTOR_SERVICE_API_KEY=

# Same Postgres database as the Next.js app connects to (source of truth
# for wallets/history/settings — see prisma/schema.prisma at the repo root).
DATABASE_URL=postgresql://user:password@host:5432/tdis

# Same AES key as the Next.js app's CONNECTOR_ENCRYPTION_KEY — this service
# is what actually decrypts credentials right before login(). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONNECTOR_ENCRYPTION_KEY=

# Firebase Admin credentials — used ONLY to mirror a successful balance
# into Firestore for the realtime dashboard. From Firebase Console ->
# Project Settings -> Service Accounts -> Generate new private key.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
