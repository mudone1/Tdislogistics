{
  "name": "tdis-connector-service",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone background service that runs Playwright-based airline connector syncs. Deployed separately from the Next.js app (VPS/Docker) — the app talks to this over its internal HTTP API, never runs Playwright itself.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/connector-service/src/server.js",
    "playwright:install": "playwright install --with-deps chromium",
    "db:generate": "prisma generate --schema=../prisma/schema.prisma"
  },
  "dependencies": {
    "express": "^4.21.2",
    "playwright": "1.61.1",
    "@prisma/client": "^6.1.0",
    "firebase-admin": "^13.0.2",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.1.0"
  }
}
