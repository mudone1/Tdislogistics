# Copy this file to .env.local and fill in your Firebase project's web config
# (Firebase Console → Project Settings → General → Your apps → SDK setup).
#
# If you leave these blank, the app still runs fully — it falls back to
# browser localStorage only (single-device, no cross-device sync). See
# FIREBASE_SETUP.md for the full walkthrough carried over from the original
# project, including the Firestore security rules to paste in.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Airline Connector Framework ───
# PostgreSQL is the source of truth for wallet sync data (separate from the
# Firestore/localStorage data above — see README.md "Airline Connector
# Framework" section for the full architecture).
DATABASE_URL=postgresql://user:password@host:5432/tdis

# Must be the SAME value as connector-service's CONNECTOR_ENCRYPTION_KEY —
# used here only to encrypt credentials on save (Admin -> Airline
# Connectors); decryption happens only inside connector-service. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONNECTOR_ENCRYPTION_KEY=

# Where the standalone connector-service is deployed (VPS/Docker/etc — see
# connector-service/README.md). NOT reachable from the browser; only this
# app's server-side API routes call it.
CONNECTOR_SERVICE_URL=http://localhost:4100
# Must match connector-service's CONNECTOR_SERVICE_API_KEY exactly.
CONNECTOR_SERVICE_API_KEY=

# ─── AI Travel Assistant (Groq) ───
# Free-tier LLM powering intent detection and conversation for the chat
# bubble. Get a key at https://console.groq.com/keys. If unset, the
# assistant falls back to the old deterministic regex parser untouched.
GROQ_API_KEY=

